{
  "name": "toolgate-mcp",
  "version": "0.3.0",
  "description": "Policy, approval, redaction, timeout, and audit middleware for MCP server tools.",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "toolgate": "dist/cli/index.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./schema": {
      "types": "./dist/manifest/schema.d.ts",
      "import": "./dist/manifest/schema.js"
    }
  },
  "files": [
    "dist",
    "examples",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "clean": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\"",
    "build": "npm run clean && tsc -p tsconfig.build.json",
    "prepack": "npm run build",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "middleware",
    "policy",
    "security",
    "audit",
    "audit-logging",
    "redaction",
    "approval",
    "guardrails",
    "cli",
    "manifest"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Wezylnia/toolgate.git",
    "directory": "packages/mcp"
  },
  "bugs": {
    "url": "https://github.com/Wezylnia/toolgate/issues"
  },
  "homepage": "https://github.com/Wezylnia/toolgate#readme",
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "minimatch": "^10.0.1"
  }
}
